# SEC EDGAR requests should identify a contact. Do not commit a real .env file.
SEC_CONTACT_EMAIL=your-email@example.com

# Ollama will be used once the local model is installed.
MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b-instruct

# Vite exposes only variables prefixed with VITE_ to the browser.
VITE_API_URL=http://localhost:8787

# Massive (formerly Polygon) market data. Keep the real key in this root .env only.
MASSIVE_API_KEY=
